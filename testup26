print("โปรแกรมคำนวณค่า mbi\n")

name = input("คุณชื่ออะไร? ")
weight = float(input("คุณหนักเท่าไหร่: กิโลกรัม "))
height = float(input("คุณสูงเท่าไหร่ : เมตร  "))
    
mbi = weight / (height * height)
print("\nค่า mbi ของคุณคือ: ", mbi)
if mbi < 18.5:
    print("น้ำหนักน้อย")
elif 18.5 <= mbi <= 22.9:
    print("ปกติ")
elif 23 <= mbi <= 24.9:
    print("น้ำหนักเกิน")
else:
    print("อ้วน")